# EditorConfig — consumed by ktlint and most IDEs.
# See https://editorconfig.org and https://ktlint.github.io/

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.{kt,kts}]
ktlint_code_style = android_studio
indent_size = 4
max_line_length = 120
ij_kotlin_allow_trailing_comma = true
ij_kotlin_allow_trailing_comma_on_call_site = true

# Keep JSON / YAML / Gradle DSL readable
[*.{json,yml,yaml}]
indent_size = 2

[*.md]
trim_trailing_whitespace = false
